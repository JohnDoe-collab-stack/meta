{
  "schema": "constructive-repairability-program/1",
  "program_version": "1.0.0",
  "status": "specification",
  "scope": {
    "core": [
      "finite deterministic public repair games",
      "constructive winning fixed point",
      "positive winning or losing certificate",
      "soundness and completeness for finite public trees",
      "explicit preservation of the actual world and prior closures"
    ],
    "extensions": [
      "worst-case cost optimality",
      "certified transfer from learned latent proposals",
      "finite adversarial response relations",
      "finite rational probabilistic responses",
      "certified finite abstractions of continuous systems"
    ],
    "non_claims": [
      "universal repairability of latent representations",
      "novelty of reachability games or active sensing",
      "unconditional correctness of neural networks",
      "general solution of partial observability",
      "historical impact before external adoption"
    ]
  },
  "constructive_constraints": {
    "axioms_allowed": false,
    "classical_allowed": false,
    "propext_allowed": false,
    "quot_sound_allowed": false,
    "external_termination_bridge_allowed": false,
    "axiom_audit_required": true
  },
  "decisions": {
    "primary_characterization": "least controllable-predecessor fixed point on an explicit finite public state carrier",
    "solver_outcomes": ["WIN certificate", "LOSE closed-region certificate"],
    "state_representation": "canonical Boolean masks plus finite memory, provenance and authorization context",
    "primary_cost": "worst-case nonnegative natural query cost among safe winning public strategies",
    "learned_trust_boundary": "a neural model proposes packets; only an independent symbolic checker can authorize a certified action",
    "first_response_model": "deterministic",
    "termination_source": "intrinsic finite state enumeration and computed fixed-point stabilization",
    "primary_empirical_profile": "single NVIDIA RTX 4070-class 12 GB workstation",
    "confirmatory_seeds": 10,
    "domains": 2,
    "learned_systems_full_profile": 7,
    "maximum_campaign_storage_gb": 30
  },
