#print axioms Meta.ClosedStabilityTheorem.PatchableArithmeticTarskiContext.genericOrbitCandidate_injective
#print axioms Meta.ClosedStabilityTheorem.PatchableArithmeticTarskiContext.genericDynamicOrbitCandidate_injective
#print axioms Meta.ClosedStabilityTheorem.PatchableArithmeticTarskiContext.genericOrbit_noExactReturn
#print axioms Meta.ClosedStabilityTheorem.PatchableArithmeticTarskiContext.genericDynamicOrbit_noExactReturn
