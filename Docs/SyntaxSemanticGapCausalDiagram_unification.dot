digraph GapUniversalUnification {
  graph [
    rankdir=TB,
    bgcolor="white",
    pad="0.35",
    nodesep="0.45",
    ranksep="0.62",
    fontname="DejaVu Sans",
    fontsize=20,
    labelloc=t,
    label="Unification causale universelle médiatisée par le gap"
  ];
  node [
    shape=box,
    style="rounded,filled",
    fontname="DejaVu Sans",
    fontsize=11,
    color="#4d4d4d",
    penwidth=1.3,
    margin="0.16,0.10"
  ];
  edge [
    fontname="DejaVu Sans",
    fontsize=9,
    color="#4a4a4a",
    arrowsize=0.72,
    penwidth=1.1
  ];

  syn [
    fillcolor="#f4f4f4",
    label="COUCHE SYNTAXIQUE COMMUNE\nSentence · Predicate · diagonal\naucune évaluation"
  ];
  k [
    fillcolor="#eaf3ff",
    color="#245a8d",
    penwidth=2.1,
    label="K — OBJET LIBRE INTRINSÈQUE VISÉ\nroot · step · Position\nEmpty à la racine · Option au successeur\naucune phrase · aucun évaluateur"
  ];
  gaporbit [
    fillcolor="#eef7f7",
    color="#276b6b",
    label="GapOrbit⁺ — STRUCTURE DE PROVENANCE\norbites positives pointées\nmorphismes préservant root · advance · new · old\néquivalence pointwise · sans quotient ni funext"
  ];
  universal [
    fillcolor="#fafafa",
    color="#777777",
    style="rounded,filled,dashed",
    label="PROPRIÉTÉ UNIVERSELLE CANDIDATE\npour toute orbite R : unique morphisme K → R\nunicité point par point\nnon encore démontrée"
  ];

  kt [
    fillcolor="#edf8ef",
    color="#34743c",
    label="K_T⁺ — SQUELETTE TARSKIEN\nétat · advance · positions\nnew_T / old_T"
  ];
  kp [
    fillcolor="#edf8ef",
    color="#34743c",
    label="K_P⁺ — SQUELETTE DE PROUVABILITÉ\nhistoire certifiée · advance · positions\nnew_P / old_P"
  ];
  dt [
    fillcolor="#fff8e5",
    color="#886500",
    label="D_T — DÉCORATION SYNTAXIQUE\ngap diagonal · patch\nlabel_T"
  ];
  dp [
    fillcolor="#fff8e5",
    color="#886500",
    label="D_P — DÉCORATION SYNTAXIQUE\nphrase de Rosser · extension\nlabel_P"
  ];
  et [
    fillcolor="#f5f0fb",
    color="#6c4a8c",
    label="ℰ_T — ÉVALUATION LOCALE\nCorrectAt · models · truthAt\nfrontier_open · position_evaluated"
  ];
  ep [
    fillcolor="#f5f0fb",
    color="#6c4a8c",
    label="ℰ_P — ÉVALUATION LOCALE\nTheoryProvable · dérivations · cohérence\nfrontier_open · position_evaluated"
  ];
  nosem [
    fillcolor="#fff0f0",
    color="#9a3434",
    style="rounded,filled,dashed",
    label="AUCUNE UNIFICATION SÉMANTIQUE\nEvaluated_T ↛ Evaluated_P\nEvaluated_P ↛ Evaluated_T"
  ];
  span [
    fillcolor="#eaf3ff",
    color="#245a8d",
    label="SPAN CANONIQUE VISÉ\nT ← K → P\nF = r_P ∘ r_T⁻¹ seulement sur les orbites engendrées"
  ];

  syn -> dt [label="syntaxe locale"];
  syn -> dp [label="syntaxe locale"];
  k -> gaporbit [style=dashed, color="#276b6b", label="initialité candidate"];
  gaporbit -> universal [style=dashed, color="#777777"];

  k -> kt [color="#245a8d", penwidth=2.0, label="r_T"];
  k -> kp [color="#245a8d", penwidth=2.0, label="r_P"];
  kt -> kp [
    dir=both,
    style=dashed,
    color="#315d80",
    label="F dérivé sur les orbites engendrées"
  ];

  kt -> dt [label="décoration locale"];
  kp -> dp [label="décoration locale"];
  dt -> et [label="le gap médiatise l’évaluation"];
  dp -> ep [label="le gap médiatise l’évaluation"];

  et -> nosem [style=dashed, arrowhead=none, color="#9a3434"];
  ep -> nosem [style=dashed, arrowhead=none, color="#9a3434"];
  k -> span [color="#245a8d", penwidth=1.6];

  { rank=same; kt; kp; }
  { rank=same; dt; dp; }
  { rank=same; et; nosem; ep; }
}
